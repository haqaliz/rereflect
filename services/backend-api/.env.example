DATABASE_URL=postgresql://user@localhost/customer_feedback_saas
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/slack/oauth/callback
FRONTEND_URL=http://localhost:3000

# Intercom OAuth
INTERCOM_CLIENT_ID=your-intercom-client-id
INTERCOM_CLIENT_SECRET=your-intercom-client-secret
INTERCOM_REDIRECT_URI=http://localhost:8000/api/v1/integrations/intercom/oauth/callback

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_your-pro-monthly-price-id
STRIPE_PRICE_PRO_ANNUAL=price_your-pro-annual-price-id
STRIPE_PRICE_BUSINESS_MONTHLY=price_your-business-monthly-price-id
STRIPE_PRICE_BUSINESS_ANNUAL=price_your-business-annual-price-id
STRIPE_PRICE_ENTERPRISE_USAGE=price_your-enterprise-metered-price-id

# Email (Resend)
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@rereflect.ca
FROM_NAME=Rereflect
APP_URL=http://localhost:3000
# Template IDs - run: python -m src.scripts.setup_email_templates --create
RESEND_TEMPLATE_TEAM_INVITE=your-team-invite-template-id
RESEND_TEMPLATE_WELCOME=your-welcome-template-id
RESEND_TEMPLATE_ALERT_NOTIFICATION=your-alert-notification-template-id

# Email Inbound (Resend Webhooks)
RESEND_INBOUND_WEBHOOK_SECRET=whsec_your-resend-inbound-webhook-secret

# Super Admin
SUPER_ADMIN_EMAIL=support@rereflect.ca
