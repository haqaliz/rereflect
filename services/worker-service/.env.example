# Redis Configuration (single instance with logical DBs)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery uses DB 0 for broker and backend
CELERY_BROKER_DB=0
CELERY_BACKEND_DB=0

# Database (same as backend-api)
DATABASE_URL=postgresql://localhost/customer_feedback_saas

# Analysis engine path
ANALYSIS_ENGINE_PATH=../analysis-engine/src

# Task configuration
ANALYSIS_BATCH_SIZE=100
ANALYSIS_TIMEOUT=600

# Retry configuration
MAX_RETRIES=3
RETRY_DELAY=60
