.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
secrets/
credentials/
*.pem
*.key
*.cert
*.crt
*.p12

# API keys and tokens
.api-keys
.tokens

# ============================================
# PROJECT SPECIFIC
# ============================================

# Sample/test data (uncomment if you don't want to track)
# sample_feedback*.csv
# test_data/

# Infrastructure state
infrastructure/**/*.tfstate
infrastructure/**/*.tfstate.backup
infrastructure/**/.terraform/
infrastructure/**/.terraform.lock.hcl

# Shared resources cache
shared/cache/

# Service-specific ignores
services/*/logs/
services/*/tmp/
services/*/cache/

# Generated changelog (exported during Docker build from git history)
services/backend-api/changelog_commits.json

# ============================================
# MISCELLANEOUS
# ============================================

# Archive files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Office files temp
~$*.doc*
~$*.xls*
~$*.ppt*

# Backup files
*.orig

# AI Tools
.claude