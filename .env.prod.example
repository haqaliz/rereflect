# =============================================================================
# Rereflect — Production / Self-Host Environment Template
# -----------------------------------------------------------------------------
# Copy to `.env` and fill in real values, then run:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# All features are unlocked on self-hosted instances (SELF_HOSTED=true).
# By default the product runs $0 on the free local VADER pipeline with NO
# LLM key required. Add your own key only if you want LLM-powered analysis.
# =============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
# Full connection string used by backend + worker.
# When using the bundled compose, this points at the `postgres` service.
DATABASE_URL=postgresql://rereflect:change_me@postgres:5432/rereflect

# Credentials the bundled `postgres` container is created with.
# Keep these in sync with DATABASE_URL above.
POSTGRES_USER=rereflect
POSTGRES_PASSWORD=change_me
POSTGRES_DB=rereflect

# ----------------------------------------------------------------------------
# Security / Secrets  (REQUIRED — generate fresh random values)
# ----------------------------------------------------------------------------
# Signs auth (JWT) tokens. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_string

# Fernet key used to encrypt BYOK LLM API keys at rest. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=change_me_generate_a_fernet_key

# ----------------------------------------------------------------------------
# First admin user (seeded on first startup)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me

# ----------------------------------------------------------------------------
# Networking
# ----------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:3000

# Public URL of the backend API. NOTE: the frontend BAKES this in at build time
# (see docker-compose.prod.yml). If you change it for a real host, you must
# REBUILD the frontend image:
#   docker compose -f docker-compose.prod.yml build frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Self-host flag — keep `true` to unlock all features with no limits.
# (Only set to `false` if you intend to run a gated/hosted multi-tenant tier.)
# ----------------------------------------------------------------------------
SELF_HOSTED=true

# ----------------------------------------------------------------------------
# AI analysis
# ----------------------------------------------------------------------------
# Default `false`: a fresh install runs entirely on the free local VADER +
# keyword pipeline ($0, no key required). Set `true` only after configuring an
# LLM key (below) to enable LLM-powered categorization, insights, and copilot.
ai_analysis_enabled=false

# ----------------------------------------------------------------------------
# OPTIONAL — Bring Your Own Key (BYOK)
# ----------------------------------------------------------------------------
# These are YOUR OWN keys for YOUR OWN single-tenant instance. Rereflect never
# provides, proxies, or pays for a key — there is no system/vendor key.
#
# The canonical place to add a key is the in-app UI (Settings -> AI), which
# stores it encrypted per organization. The env vars below are a convenience
# for single-tenant operators who prefer to seed a key from the environment.
# Leave them blank to run on the free VADER pipeline.
#
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=
